{
  "name": "lights-out-electron",
  "version": "10.3.0",
  "description": "Lights Out - Sleep Timer (Electron Edition)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win",
    "icons": "node scripts/make-icons.js",
    "smoke": "node scripts/smoke-test.js",
    "test": "node --test"
  },
  "author": "Lights Out",
  "license": "MIT",
  "build": {
    "appId": "com.lightsout.sleep-timer",
    "productName": "Lights Out",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "smartLights.js",
      "profiles.js",
      "calendar.js",
      "settings.js",
      "lastLight.js",
      "streaks.js",
      "alarm.js",
      "updater.js",
      "calendarProviders.js",
      "companion.js",
      "companion.html",
      "media.js",
      "unsavedGuard.js",
      "family.js",
      "remoteControl.js",
      "wifiGuard.js",
      "contentBlocker.js",
      "accountability.js",
      "focusSessions.js",
      "screenTime.js",
      "sleepDebt.js",
      "emergencyOverride.js",
      "runReceipts.js",
      "ambientVisuals.js",
      "idleDetection.js",
      "bedtimeReminder.js",
      "overrideTax.js",
      "autopilot.js",
      "ritualMode.js",
      "statsDashboard.js",
      "smartSuggestions.js",
      "widget.html",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Lights Out"
    },
    "portable": {
      "artifactName": "LightsOut.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lights Out"
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "ws": "^8.21.0"
  }
}
