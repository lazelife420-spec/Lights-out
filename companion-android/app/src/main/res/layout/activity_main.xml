<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/setup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:minHeight="560dp"
            android:paddingHorizontal="28dp"
            android:paddingVertical="40dp">

            <FrameLayout
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:background="@drawable/bg_hero_badge"
                android:layout_marginBottom="22dp">

                <ImageView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_moon"
                    android:contentDescription="@string/app_name" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:letterSpacing="0.35"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_title"
                android:textColor="@color/text"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_hint"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="24dp"
                android:paddingHorizontal="6dp" />

            <Button
                android:id="@+id/scan_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/btn_accent"
                android:text="@string/scan_qr"
                android:textColor="#0B0E14"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:stateListAnimator="@null"
                android:textAllCaps="false"
                android:drawableStart="@drawable/ic_scan"
                android:drawablePadding="10dp"
                android:paddingHorizontal="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/or_paste"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:layout_marginVertical="16dp" />

            <EditText
                android:id="@+id/url_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:hint="@string/url_hint"
                android:textColor="@color/text"
                android:textColorHint="@color/text_dim"
                android:textColorHighlight="#335B8CFF"
                android:inputType="textUri"
                android:autofillHints="url"
                android:maxLines="3"
                android:paddingHorizontal="16dp"
                android:paddingVertical="15dp"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/connect_button"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:text="@string/connect"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:textAllCaps="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_footer"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="22dp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
